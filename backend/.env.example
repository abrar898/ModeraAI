# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/content-moderation?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_change_in_production

# Optional separate secret for signing short-lived image access tokens.
# Falls back to JWT_SECRET if not set.
IMAGE_TOKEN_SECRET=your_image_token_secret_here

# ── AI moderation (at least one required) ─────────────────────────────────────
GROQ_API_KEY=gsk_your-key-here
GEMINI_API_KEY=AIza_your-key-here

# ── Image storage (optional — falls back to MongoDB binary storage) ───────────
# Works with AWS S3, Cloudflare R2, MinIO, or any S3-compatible provider.
# Leave blank to store images in MongoDB (fine for development/small scale).
S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
# For Cloudflare R2 or MinIO, set a custom endpoint:
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ── Email (optional — appeal notifications are skipped if not set) ────────────
# Get a free API key at https://resend.com
RESEND_API_KEY=re_your-key-here
# Must be a verified sender address in your Resend account
EMAIL_FROM=ModeraAI <onboarding@resend.dev>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
