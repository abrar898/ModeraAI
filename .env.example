# MongoDB Atlas connection string
# Get this from Atlas → Database → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your Atlas credentials
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/content-moderation?retryWrites=true&w=majority

# Secret used to sign JWT auth tokens — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# Groq API key for AI-powered image moderation (free tier, no credit card required)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Gemini API key used as a fallback if Groq fails or hits its rate limit (free tier)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_your-key-here

# URL the frontend is served from (used for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Optional: Resend email for appeal resolution notifications
# Get a free key at https://resend.com — without this, users still get in-app notifications
# Free tier only sends to your verified email address until you verify a domain
RESEND_API_KEY=re_your-key-here
EMAIL_FROM=ModeraAI <onboarding@resend.dev>
